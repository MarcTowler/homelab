global:
  scrape_interval: 30s
  scrape_timeout: 10s
  evaluation_interval: 30s
  external_labels:
    cluster: 'homelab'
    environment: 'production'

# Alerting configuration
alerting:
  alertmanagers:
    - static_configs:
        - targets: []

# Load rules once and periodically evaluate them
rule_files:
  - "{{ prometheus_config_dir }}/alert-rules.yml"

# Scrape configurations
scrape_configs:
  # Prometheus self-monitoring
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ prometheus_port }}']

  # Node Exporters - All hosts with node exporter enabled
  - job_name: 'node-exporters'
    static_configs:
{% if groups['node_exporters'] is defined %}
      - targets:
{% for host in groups['node_exporters'] %}
          - '{{ host }}.{{ domain_name }}:9100'
{% endfor %}
        labels:
          group: 'infrastructure'
{% endif %}
{% if groups['proxmox_node_exporters'] is defined %}
{% for host in groups['proxmox_node_exporters'] %}
      - targets:
          - '{{ hostvars[host].ansible_host }}:9100'
        labels:
          group: 'infrastructure'
          instance: '{{ host }}.{{ domain_name }}'
{% endfor %}
{% endif %}
    relabel_configs:
      # Extract hostname from FQDN:port format for LXC containers (only if starts with letter)
      - source_labels: [__address__]
        regex: '^([a-zA-Z][a-zA-Z0-9.-]*):.*'
        target_label: instance
        replacement: '${1}'

  # MySQL Exporters - All hosts with mysql exporter enabled
{% if groups.get('mysql_exporters', []) | length > 0 %}
  - job_name: 'mysql-exporters'
    static_configs:
      - targets:
{% for host in groups['mysql_exporters'] %}
          - '{{ host }}.{{ domain_name }}:9104'
{% endfor %}
        labels:
          group: 'database'
    relabel_configs:
      # Extract hostname from FQDN:port format
      - source_labels: [__address__]
        regex: '([^:]+):.*'
        target_label: instance
        replacement: '${1}'
{% endif %}

  # Traefik Reverse Proxy Metrics
{% if groups.get('traefik', []) | length > 0 %}
  - job_name: 'traefik'
    static_configs:
      - targets:
{% for host in groups['traefik'] %}
          - '{{ host }}.{{ domain_name }}:8080'
{% endfor %}
        labels:
          group: 'networking'
          service: 'traefik'
    metrics_path: '/metrics'
    relabel_configs:
      # Extract hostname from FQDN:port format
      - source_labels: [__address__]
        regex: '([^:]+):.*'
        target_label: instance
        replacement: '${1}'
{% endif %}

  # Optional: Proxmox API Monitoring (requires proxmox_exporter)
  # - job_name: 'proxmox-api'
  #   static_configs:
  #     - targets:
  #         - 'localhost:8001'
  #       labels:
  #         cluster: 'pve'
