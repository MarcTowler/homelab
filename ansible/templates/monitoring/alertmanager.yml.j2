alerting:
  resolve_timeout: 5m

global:
  resolve_timeout: 5m
  slack_api_url: '{{ slack_webhook_url | default("") }}'
  # Discord webhook URLs are configured per receiver

route:
  receiver: 'default'
  group_by: ['alertname', 'cluster', 'service']
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 12h

  routes:
    - match:
        severity: critical
      receiver: 'critical'
      group_wait: 0s
      repeat_interval: 4h

    - match:
        severity: warning
      receiver: 'warning'
      repeat_interval: 24h

receivers:
  - name: 'default'
    {% if slack_webhook_url is defined and slack_webhook_url %}
    slack_configs:
      - channel: '#alerts'
        title: 'Homelab Alert: {{ .GroupLabels.alertname }}'
        text: '{{ range .Alerts }}{{ .Annotations.description }}{{ end }}'
    {% endif %}
    {% if discord_webhook_url is defined and discord_webhook_url %}
    discord_configs:
      - webhook_url: '{{ discord_webhook_url }}'
        title: 'Homelab Alert: {{ .GroupLabels.alertname }}'
        message: '{{ range .Alerts }}{{ .Annotations.description }}{{ end }}'
    {% endif %}

  - name: 'critical'
    {% if slack_webhook_url is defined and slack_webhook_url %}
    slack_configs:
      - channel: '#critical-alerts'
        title: '🚨 CRITICAL: {{ .GroupLabels.alertname }}'
        text: '{{ range .Alerts }}{{ .Annotations.description }}{{ end }}'
    {% endif %}
    {% if discord_webhook_url_critical is defined and discord_webhook_url_critical %}
    discord_configs:
      - webhook_url: '{{ discord_webhook_url_critical }}'
        title: '🚨 CRITICAL: {{ .GroupLabels.alertname }}'
        message: '{{ range .Alerts }}{{ .Annotations.description }}{{ end }}'
    {% endif %}

  - name: 'warning'
    {% if slack_webhook_url is defined and slack_webhook_url %}
    slack_configs:
      - channel: '#alerts'
        title: '⚠️ WARNING: {{ .GroupLabels.alertname }}'
        text: '{{ range .Alerts }}{{ .Annotations.description }}{{ end }}'
    {% endif %}
    {% if discord_webhook_url is defined and discord_webhook_url %}
    discord_configs:
      - webhook_url: '{{ discord_webhook_url }}'
        title: '⚠️ WARNING: {{ .GroupLabels.alertname }}'
        message: '{{ range .Alerts }}{{ .Annotations.description }}{{ end }}'
    {% endif %}

  # Default null receiver (silences alerts if no webhooks configured)
  - name: 'null'

inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match_re:
      severity: 'warning|info'
    equal: ['alertname', 'instance']
