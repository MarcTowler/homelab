# Traefik Static Configuration
# Generated by Ansible - Auto-managed

[global]
  checkNewVersion = true
  sendAnonymousUsage = true

# Entry Points
[entryPoints]
  [entryPoints.web]
    address = "0.0.0.0:{{ traefik_http_port }}"

  [entryPoints.websecure]
    address = "0.0.0.0:{{ traefik_https_port }}"

  [entryPoints.traefik]
    address = "0.0.0.0:{{ traefik_api_port }}"

# API & Dashboard
[api]
  dashboard = {{ traefik_api_dashboard | lower }}
  insecure = false
  debug = false

# Providers
[providers]
  # File provider for dynamic configuration
  [providers.file]
    directory = "/etc/traefik/dynamic"
    watch = true
    debugLogGeneratedTemplate = false

# Certificate Resolvers with ACME
[certificatesResolvers.letsencrypt.acme]
  email = "{{ traefik_acme_email }}"
  storage = "/etc/traefik/acme/acme.json"
  keyType = "EC384"

  # DNS Challenge using Cloudflare (passed via environment variable)
  [certificatesResolvers.letsencrypt.acme.dnsChallenge]
    provider = "cloudflare"
    delayBeforeCheck = 0
    resolvers = ["1.1.1.1:53", "8.8.8.8:53"]

# Logging
[log]
  level = "INFO"
  filePath = "/var/log/traefik/traefik.log"

# Access Log
[accessLog]
  filePath = "/var/log/traefik/access.log"
  format = "json"
  bufferingSize = 100

# Metrics for Prometheus
# Exposes metrics at http://localhost:8080/metrics
[metrics]
  [metrics.prometheus]
    addEntryPointsLabels = true
    addServicesLabels = true
    addRoutersLabels = true
    manualRouting = false
    buckets = [0.1, 0.3, 1.2, 5.0]

# Tracing (optional - disabled by default)
# [tracing]
#   serviceName = "traefik"
#   [tracing.jaeger]
#     samplingServerURL = "http://localhost:6831"
