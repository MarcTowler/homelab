# Traefik Dynamic Configuration - Services
# Auto-generated from Ansible inventory
# Generated at: {{ ansible_date_time.iso8601 }}

# Service IP mapping (from Ansible inventory)
{% set service_hosts = {
  'api': '10.0.1.47',
  'gapi': '10.0.1.38',
  'site': '10.0.1.166',
  'homepage': '10.0.1.178',
  'monitoring': '10.0.1.87',
  'monitoring_prometheus': '10.0.1.87',
  'monitoring_grafana': '10.0.1.87',
  'game-server': '10.0.1.48',
  'sonarr': '10.0.1.201',
  'radarr': '10.0.1.201',
  'lidarr': '10.0.1.201',
  'prowlarr': '10.0.1.201',
  'bazarr': '10.0.1.201',
  'readarr': '10.0.1.201',
  'qbittorrent': '10.0.1.201',
  'flarearr': '10.0.1.201'
} %}

# Generate routers and services for each mapped service
{% for service_name, port in service_port_mapping.items() %}

# {{ service_name | replace('_', ' ') | title }} Service - HTTP to HTTPS redirect
[http.routers.{{ service_name }}-http]
  rule = "Host(`{{ service_subdomains[service_name] }}.{{ domain_name }}`)"
  service = "{{ service_name }}-service"
  entryPoints = ["web"]
  middlewares = ["redirect-https"]

# {{ service_name | replace('_', ' ') | title }} Service - HTTPS
[http.routers.{{ service_name }}]
  rule = "Host(`{{ service_subdomains[service_name] }}.{{ domain_name }}`)"
  service = "{{ service_name }}-service"
  entryPoints = ["websecure"]
  {% if service_name in ['sonarr', 'radarr', 'lidarr', 'prowlarr', 'bazarr', 'readarr', 'qbittorrent', 'flarearr'] %}
  middlewares = ["add-headers", "media-arr-auth"]
  {% else %}
  middlewares = ["add-headers"]
  {% endif %}
  {% if service_name == 'homepage' %}
  stripPrefix = false
  {% endif %}
  
  [http.routers.{{ service_name }}.tls]
    certResolver = "letsencrypt"
    [[http.routers.{{ service_name }}.tls.domains]]
      main = "{{ domain_name }}"
      sans = ["*.{{ domain_name }}"]

[http.services.{{ service_name }}-service]
  [http.services.{{ service_name }}-service.loadBalancer]
    [[http.services.{{ service_name }}-service.loadBalancer.servers]]
      url = "http://{{ service_hosts[service_name] }}:{{ port }}"

{% endfor %}

# Middleware for HTTP to HTTPS redirect
[http.middlewares]
  [http.middlewares.redirect-https.redirectScheme]
    scheme = "https"
    permanent = true

  # Headers middleware to ensure applications know they're behind HTTPS
  [http.middlewares.add-headers.headers]
    [http.middlewares.add-headers.headers.customRequestHeaders]
      X-Forwarded-Proto = "https"
      X-Forwarded-Host = "{{ domain_name }}"
      X-Forwarded-Port = "443"

  # Basic Auth for media-arr services
  [http.middlewares.media-arr-auth.basicAuth]
    users = [
      "{{ media_arr_auth_user }}:{{ media_arr_auth_password }}"
    ]
    removeHeader = true

# Minecraft Server - TCP Routing (Raw TCP passthrough)
[tcp.routers.minecraft-server]
  rule = "HostSNI(`*`)"
  service = "minecraft-backend"
  entryPoints = ["minecraft"]

[tcp.services.minecraft-backend]
  [tcp.services.minecraft-backend.loadBalancer]
    [[tcp.services.minecraft-backend.loadBalancer.servers]]
      address = "{{ service_hosts['game-server'] }}:25565"

# Traefik Dashboard & API (internal - no external exposure)
[http.routers.traefik-dashboard]
  rule = "Path(`/dashboard`) || Path(`/api`)"
  service = "api@internal"
  entryPoints = ["traefik"]
  # No TLS on internal entry point
