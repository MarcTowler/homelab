- Deployed Containers:
{% for key, item in homepage_containers.items() %}
    - {{ item.name }}:
        icon: {{ item.icon }}
        ping: "https://{{ item.ip }}"
        href: "https://{{ item.name }}.itslit.me.uk"
        proxmoxNode: {{ item.node }}
        proxmoxVMID: {{ item.vmid }}
        proxmoxType: lxc
{% endfor %}

- Developer:
    - GitHub Runners:
        icon: github.png
        href: "https://github.com/ItsLit-Media-and-Development/settings/actions/runners"
        ping: "http://localhost:3001/health"
        widget:
          type: customapi
          url: http://localhost:3001/api/runners
          mappings:
            - field: summary.total
              label: Total
              format: number
            - field: summary.active
              label: Active
              format: number
            - field: summary.idle
              label: Idle
              format: number
            - field: summary.offline
              label: Offline
              format: number
    - Runner Jobs:
        widget:
          type: customapi
          url: http://localhost:3001/api/runners
          display: dynamic-list
          mappings:
            items: runners
            name: name
            label: current_job
            format: text