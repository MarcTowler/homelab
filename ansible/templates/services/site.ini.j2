[site]
TOKEN = {{ php_token}}
TEST_TOKEN = {{ php_test_token}}
BASE_URL = "http://{{ ansible_hostname }}.{{ domain_name }}/"
{% if ansible_hostname == "site" %}
API_USER = {{ api_user }}
API_KEY = {{ php_token}}
NAME  = "ItsLittany | Streamer, Gamer and Tech Enthusiast"
TITLE = "itslit.uk | Multiplayer Gaming and Live-streaming Professional"
{% endif %}

[twitch]
CLIENT_ID     = {{ twitch_client_id }}
TWITCH_SECRET = {{ twitch_secret }}
WEBHOOK_SECRET = {{ twitch_webhook_secret }}

[streamlabs]
SL_CLIENT_ID = {{ sl_client_id }}
SL_SECRET   = {{ sl_secret }}

[database]

DBHOST = "db.itslit.me.uk"
PORT   = 3306
DBNAME = "marctowl_itslitapi"
DBUSER = {{ dbuser }}
DBPASS = {{ dbpass }}

[riot]
RIOT_API_KEY = {{ riot_api_key }}