#!/bin/bash
# LitBot CLI Wrapper Script
# Automatically generated by Ansible

# Resolve the actual script location (follow symlinks)
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
PROJECT_DIR="$(dirname "$SCRIPT_PATH")"
DOTNET_ROOT="/usr"

# Find the main DLL file
MAIN_DLL=$(find "$PROJECT_DIR" -maxdepth 1 -name "*.dll" -type f | head -n 1)

if [ -z "$MAIN_DLL" ]; then
  echo "Error: Could not find main DLL file in $PROJECT_DIR"
  exit 1
fi

# Execute the application with passed arguments
exec dotnet "$MAIN_DLL" "$@"
