/**
 * GitHub Runners Status API Service (Lightweight Version)
 * 
 * Uses built-in Node.js http module (no dependencies required)
 * Provides real-time status of GitHub Actions runners
 * 
 * Environment Variables:
 *   GITHUB_PAT - Organization GitHub token
 *   GITHUB_PAT_PERSONAL - Personal account GitHub token
 */

const http = require('http');
const https = require('https');
const { URL } = require('url');

const GITHUB_API_URL = 'https://api.github.com';
const GITHUB_PAT = process.env.GITHUB_PAT || '{{ github_pat }}';
const GITHUB_PAT_PERSONAL = process.env.GITHUB_PAT_PERSONAL || '{{ github_pat_personal | default("") }}';
const ORG_NAME = 'ItsLit-Media-and-Development';
const PERSONAL_REPOS = [
  'marctowler/homelab',
  'marctowler/LitBot',
  'marctowler/Elrakis.NET'
];

/**
 * Make HTTPS request to GitHub API
 */
function httpsRequest(url, options = {}) {
  return new Promise((resolve, reject) => {
    const request = https.get(url, {
      headers: {
        'Authorization': `token ${options.token}`,
        'Accept': 'application/vnd.github.v3+json',
        'User-Agent': 'GitHub-Runners-Dashboard'
      }
    }, (response) => {
      let data = '';
      response.on('data', chunk => { data += chunk; });
      response.on('end', () => {
        try {
          resolve(JSON.parse(data));
        } catch (e) {
          resolve({ error: 'Failed to parse response' });
        }
      });
    });
    
    request.on('error', reject);
    request.setTimeout(5000, () => {
      request.destroy();
      reject(new Error('Request timeout'));
    });
  });
}

/**
 * Fetch runners from GitHub API
 */
async function getRunners(token, scope, value) {
  try {
    let url;
    if (scope === 'org') {
      url = `${GITHUB_API_URL}/orgs/${value}/actions/runners`;
    } else {
      url = `${GITHUB_API_URL}/repos/${value}/actions/runners`;
    }

    const data = await httpsRequest(url, { token });
    return data.runners || [];
  } catch (error) {
    console.error(`Error fetching ${scope} ${value}:`, error.message);
    return [];
  }
}

/**
 * Main request handler
 */
async function requestHandler(req, res) {
  // CORS headers
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'GET, OPTIONS');
  res.setHeader('Content-Type', 'application/json');

  if (req.method === 'OPTIONS') {
    res.writeHead(200);
    res.end();
    return;
  }

  if (req.url === '/health') {
    res.writeHead(200);
    res.end(JSON.stringify({ status: 'healthy', timestamp: new Date().toISOString() }));
    return;
  }

  if (req.url === '/api/runners') {
    try {
      const runners = [];

      // Fetch org runners
      if (GITHUB_PAT) {
        const orgRunners = await getRunners(GITHUB_PAT, 'org', ORG_NAME);
        for (const runner of orgRunners) {
          const runnerObj = {
            id: runner.id,
            name: runner.name,
            status: runner.status,
            busy: runner.busy,
            os: runner.os,
            scope: 'organization',
            scoped_to: ORG_NAME,
            labels: runner.labels?.map(l => l.name) || [],
            current_job: (runner.busy && runner.current_job) ? runner.current_job : "No job",
            created_at: runner.created_at,
            updated_at: runner.updated_at
          };
          runners.push(runnerObj);
        }
      }

      // Fetch personal repo runners
      if (GITHUB_PAT_PERSONAL) {
        for (const repo of PERSONAL_REPOS) {
          try {
            const repoRunners = await getRunners(GITHUB_PAT_PERSONAL, 'repo', repo);
            for (const runner of repoRunners) {
              const runnerObj = {
                id: runner.id,
                name: runner.name,
                status: runner.status,
                busy: runner.busy,
                os: runner.os,
                scope: 'repository',
                scoped_to: repo,
                labels: runner.labels?.map(l => l.name) || [],
                current_job: (runner.busy && runner.current_job) ? runner.current_job : "No job",
                created_at: runner.created_at,
                updated_at: runner.updated_at
              };
              runners.push(runnerObj);
            }
          } catch (e) {
            console.error(`Error fetching runners for ${repo}:`, e.message);
          }
        }
      }

      const response = {
        success: true,
        timestamp: new Date().toISOString(),
        runners: runners,
        summary: {
          total: runners.length,
          active: runners.filter(r => r.busy).length,
          idle: runners.filter(r => !r.busy && r.status === 'online').length,
          offline: runners.filter(r => r.status === 'offline').length
        }
      };

      res.writeHead(200);
      res.end(JSON.stringify(response, null, 2));
    } catch (error) {
      console.error('Error in /api/runners:', error);
      res.writeHead(500);
      res.end(JSON.stringify({
        success: false,
        error: error.message
      }));
    }
    return;
  }

  res.writeHead(404);
  res.end(JSON.stringify({ error: 'Not found' }));
}

const PORT = process.env.PORT || 3001;
const server = http.createServer(requestHandler);

server.listen(PORT, () => {
  console.log(`GitHub Runners API service listening on port ${PORT}`);
  console.log(`Health check: http://localhost:${PORT}/health`);
  console.log(`Runners status: http://localhost:${PORT}/api/runners`);
});

